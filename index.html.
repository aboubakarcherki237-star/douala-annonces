// ══ TOAST ══
function showToast(icon,text){
  const c=document.getElementById('toastC');
  const t=document.createElement('div');
  t.className='toast';
  t.innerHTML=`<span class="toast-icon">${icon}</span><span class="toast-text">${text}</span>`;
  c.appendChild(t);
  setTimeout(()=>{ t.style.cssText='opacity:0;transform:translateX(110%);transition:all 0.3s'; setTimeout(()=>t.remove(),300); },3500);
}

