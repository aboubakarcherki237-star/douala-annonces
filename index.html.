let postStep=1, postData={}, selPlan='free', uploadedImgs=[];

function initPost(){ postStep=1; postData={}; uploadedImgs=[]; renderPostStep(); }

function setPostTab(active){
  for(let i=1;i<=4;i++){
    const t=document.getElementById('ptab'+i);
    if(!t) continue;
    t.className='step-tab '+(i<active?'done':i===active?'active':'');
  }
}

