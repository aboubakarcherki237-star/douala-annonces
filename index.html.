          <option>Yaoundé — Centre</option><option>Yaoundé — Bastos</option><option>Yaoundé — Melen</option>
          <option>Bafoussam</option><option>Garoua</option><option>Autre ville</option>
        </select>
      </div>
      <div class="form-group"><label class="form-label">Votre numéro (WhatsApp) *</label><input class="form-input" type="tel" placeholder="+237 6 00 00 00 00" id="pPhone" value="${postData.phone||''}"></div>
      <div class="form-group"><label class="form-label">Email (optionnel)</label><input class="form-input" type="email" placeholder="votre@email.com" id="pEmail"></div>
      <div class="form-group">
        <div style="display:flex;align-items:center;gap:8px">
          <input type="checkbox" id="pShowPhone" checked style="accent-color:var(--green);width:16px;height:16px">
          <label for="pShowPhone" style="font-size:0.8rem;color:var(--ink2)">Afficher mon numéro dans l'annonce</label>
