        <button class="btn-post" onclick="go('post')">+ Publier la première annonce</button>
      </div>`;
    return;
  }
  document.getElementById('adsGrid').innerHTML=list.map((a,i)=>`
    <div class="ad-card" style="animation:fadeUp 0.4s ease both ${i*0.06}s" onclick="showDetail(${a.id})">
      <div class="ad-img">
        ${a.icon}
        ${a.badge?`<span class="ad-badge badge-${a.badge}">${a.badge==='urgent'?'Urgent':a.badge==='new'?'Nouveau':'Premium'}</span>`:''}
        <button class="ad-fav" onclick="event.stopPropagation();toggleFav(${a.id},this)">${a.fav?'❤️':'🤍'}</button>
      </div>
      <div class="ad-body">
        <div class="ad-cat">${a.cat}</div>
        <div class="ad-title">${a.title}</div>
        <div style="margin-top:6px">
          <span class="ad-price">${fmt(a.price)}</span>
          ${a.old?`<span class="ad-price-old">${fmt(a.old)}</span>`:''}
        </div>
        <div class="ad-meta">
          <span class="ad-loc">📍 ${a.loc}</span>
          <span class="ad-time">${a.time}</span>
        </div>
      </div>
    </div>`).join('');
}

function toggleFav(id,btn){
  const ad=ADS.find(a=>a.id===id);
  if(ad){ ad.fav=!ad.fav; btn.textContent=ad.fav?'❤️':'🤍'; showToast(ad.fav?'❤️':'🗑️',ad.fav?'Ajouté aux favoris':'Retiré des favoris'); }
}

function filterAds(btn,cat){
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
  btn.classList.add('active');
  renderAds(cat?ADS.filter(a=>a.cat===cat||a.cat.includes(cat)):ADS);
}

function filterByCat(cat){
  document.querySelector('.listings-section').scrollIntoView({behavior:'smooth'});
  const list=cat?ADS.filter(a=>a.cat===cat):ADS;
  renderAds(list);
  document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
}

function sortAds(val){
  let list=[...ADS];
  if(val==='price-asc') list.sort((a,b)=>a.price-b.price);
  else if(val==='price-desc') list.sort((a,b)=>b.price-a.price);
  renderAds(list);
}

function doSearch(){
  const q=document.getElementById('searchQ').value.toLowerCase();
  const cat=document.getElementById('searchCat').value;
  let list=ADS;
  if(q) list=list.filter(a=>a.title.toLowerCase().includes(q)||a.cat.toLowerCase().includes(q));
  if(cat) list=list.filter(a=>a.cat===cat);
  document.querySelector('.listings-section').scrollIntoView({behavior:'smooth'});
  renderAds(list);
  if(list.length===0) document.getElementById('adsGrid').innerHTML='<div style="grid-column:1/-1;text-align:center;padding:40px;color:var(--ink3)"><div style="font-size:2.5rem;margin-bottom:10px">🔍</div><div style="font-family:Syne,sans-serif;font-weight:800;margin-bottom:6px">Aucun résultat</div><div style="font-size:0.82rem">Essayez d\'autres mots-clés</div></div>';
}

