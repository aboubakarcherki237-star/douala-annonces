<style>
:root{
  --bg:#F7F4EF;--bg2:#EDE9E2;--bg3:#E2DDD4;
  --ink:#1A1410;--ink2:#3D3530;--ink3:#6B6058;
  --green:#1B6B45;--green2:#2A9060;--green3:#E8F5EE;--green4:rgba(27,107,69,0.1);
  --red:#C0392B;--red2:rgba(192,57,43,0.1);
  --gold:#C8991A;--gold2:#F5E6B0;
  --white:#FFFFFF;
  --border:#D8D1C6;--border2:#C5BBAE;
  --r:10px;--r2:16px;--shadow:0 4px 24px rgba(26,20,16,0.1);--shadow2:0 12px 48px rgba(26,20,16,0.15);
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{font-family:'Inter',sans-serif;background:var(--bg);color:var(--ink);min-height:100vh;overflow-x:hidden}
::-webkit-scrollbar{width:4px}::-webkit-scrollbar-track{background:var(--bg2)}::-webkit-scrollbar-thumb{background:var(--green);border-radius:4px}
.hidden{display:none!important}

@keyframes fadeUp{from{opacity:0;transform:translateY(20px)}to{opacity:1;transform:translateY(0)}}
@keyframes slideIn{from{transform:translateX(110%);opacity:0}to{transform:translateX(0);opacity:1}}
@keyframes spin{to{transform:rotate(360deg)}}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:0.5}}

/* ── NAV ── */
nav{position:fixed;top:0;left:0;right:0;z-index:100;height:60px;display:flex;align-items:center;justify-content:space-between;padding:0 20px;background:var(--white);border-bottom:2px solid var(--ink);box-shadow:0 2px 0 var(--border)}
.logo{font-family:'Syne',sans-serif;font-size:1.3rem;font-weight:800;color:var(--ink);cursor:pointer;display:flex;align-items:center;gap:6px;letter-spacing:-0.02em}
.logo-dot{width:10px;height:10px;background:var(--green);border-radius:50%;display:inline-block}
.nav-links{display:flex;gap:2px}
.nav-btn{background:none;border:none;font-family:'Inter',sans-serif;font-size:0.8rem;font-weight:500;color:var(--ink3);padding:7px 12px;border-radius:8px;cursor:pointer;transition:all 0.2s;white-space:nowrap}
.nav-btn:hover,.nav-btn.active{color:var(--green);background:var(--green3)}
.nav-right{display:flex;gap:8px;align-items:center}
.btn-post{background:var(--green);color:var(--white);border:none;font-family:'Syne',sans-serif;font-size:0.82rem;font-weight:700;padding:9px 18px;border-radius:var(--r);cursor:pointer;transition:all 0.2s;white-space:nowrap}
.btn-post:hover{background:var(--green2);transform:translateY(-1px)}
.hamburger{display:none;background:none;border:none;font-size:1.4rem;cursor:pointer;color:var(--ink)}
.avatar-nav{width:34px;height:34px;border-radius:8px;background:var(--green);color:var(--white);display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.75rem;cursor:pointer;border:2px solid var(--ink)}

/* ── PAGES ── */
.page{min-height:100vh;padding-top:60px;position:relative}

/* ══ HOME ══ */
.hero{background:var(--ink);color:var(--white);padding:60px 20px 50px;text-align:center;position:relative;overflow:hidden}
.hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 70% 80% at 50% 100%,rgba(27,107,69,0.3) 0%,transparent 60%)}
.hero-eyebrow{display:inline-flex;align-items:center;gap:6px;background:rgba(255,255,255,0.08);border:1px solid rgba(255,255,255,0.15);color:rgba(255,255,255,0.75);font-size:0.72rem;font-weight:600;text-transform:uppercase;letter-spacing:0.1em;padding:5px 14px;border-radius:100px;margin-bottom:22px}
.hero-title{font-family:'Syne',sans-serif;font-size:clamp(2rem,5vw,3.8rem);font-weight:800;line-height:1.08;letter-spacing:-0.03em;margin-bottom:14px}
.hero-title span{color:var(--green2)}
.hero-sub{color:rgba(255,255,255,0.65);font-size:0.96rem;line-height:1.7;max-width:500px;margin:0 auto 32px}

/* Search bar */
.search-bar{max-width:700px;margin:0 auto;background:var(--white);border-radius:var(--r2);padding:8px;display:flex;gap:8px;box-shadow:0 8px 32px rgba(0,0,0,0.3);position:relative;z-index:2}
.search-input{flex:1;border:none;outline:none;font-family:'Inter',sans-serif;font-size:0.92rem;color:var(--ink);padding:10px 14px;background:transparent}
.search-input::placeholder{color:var(--ink3)}
.search-cat{border:none;outline:none;font-family:'Inter',sans-serif;font-size:0.82rem;color:var(--ink2);padding:10px 10px;background:var(--bg2);border-radius:8px;cursor:pointer;width:140px}
.btn-search{background:var(--green);color:var(--white);border:none;padding:11px 22px;border-radius:10px;font-family:'Syne',sans-serif;font-size:0.86rem;font-weight:700;cursor:pointer;transition:all 0.2s;white-space:nowrap}
.btn-search:hover{background:var(--green2)}

/* hero stats */
.hero-stats{display:flex;gap:0;justify-content:center;margin-top:36px;flex-wrap:wrap}
.hstat{padding:16px 28px;text-align:center;border-right:1px solid rgba(255,255,255,0.1)}
.hstat:last-child{border-right:none}
.hstat-n{font-family:'Syne',sans-serif;font-size:1.6rem;font-weight:800;color:var(--white)}
.hstat-l{font-size:0.7rem;color:rgba(255,255,255,0.5);text-transform:uppercase;letter-spacing:0.08em;margin-top:2px}

/* Categories */
.cats-section{padding:40px 20px;max-width:1100px;margin:0 auto}
.section-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:20px}
.section-title{font-family:'Syne',sans-serif;font-size:1.2rem;font-weight:800;color:var(--ink)}
.see-all{font-size:0.8rem;color:var(--green);font-weight:600;cursor:pointer;border:none;background:none}
.see-all:hover{color:var(--green2);text-decoration:underline}
.cats-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(130px,1fr));gap:10px}
.cat-card{background:var(--white);border:1.5px solid var(--border);border-radius:var(--r2);padding:18px 12px;text-align:center;cursor:pointer;transition:all 0.2s}
.cat-card:hover{border-color:var(--green);background:var(--green3);transform:translateY(-2px)}
.cat-card.active{border-color:var(--green);background:var(--green3)}
.cat-icon{font-size:1.8rem;margin-bottom:8px}
.cat-name{font-size:0.78rem;font-weight:600;color:var(--ink2)}
.cat-count{font-size:0.68rem;color:var(--ink3);margin-top:2px}

/* Listings */
.listings-section{padding:10px 20px 60px;max-width:1100px;margin:0 auto}
.filters-bar{display:flex;gap:8px;margin-bottom:20px;flex-wrap:wrap;align-items:center}
.filter-btn{padding:7px 14px;border:1.5px solid var(--border);border-radius:100px;font-size:0.78rem;font-weight:500;color:var(--ink2);background:var(--white);cursor:pointer;transition:all 0.2s;white-space:nowrap}
.filter-btn:hover,.filter-btn.active{border-color:var(--green);color:var(--green);background:var(--green3)}
.sort-select{margin-left:auto;padding:7px 12px;border:1.5px solid var(--border);border-radius:100px;font-size:0.78rem;color:var(--ink2);background:var(--white);cursor:pointer;outline:none}
.ads-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(250px,1fr));gap:16px}
.ad-card{background:var(--white);border:1.5px solid var(--border);border-radius:var(--r2);overflow:hidden;cursor:pointer;transition:all 0.25s}
.ad-card:hover{border-color:var(--green);transform:translateY(-4px);box-shadow:var(--shadow2)}
.ad-img{width:100%;height:160px;object-fit:cover;background:var(--bg2);display:flex;align-items:center;justify-content:center;font-size:3rem;position:relative}
.ad-badge{position:absolute;top:10px;left:10px;font-size:0.66rem;font-weight:800;text-transform:uppercase;letter-spacing:0.06em;padding:3px 9px;border-radius:100px}
.badge-urgent{background:var(--red);color:var(--white)}
.badge-new{background:var(--green);color:var(--white)}
.badge-premium{background:var(--gold);color:var(--ink)}
.ad-fav{position:absolute;top:10px;right:10px;width:30px;height:30px;background:var(--white);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.9rem;border:none;cursor:pointer;transition:all 0.2s;box-shadow:0 2px 8px rgba(0,0,0,0.15)}
.ad-fav:hover{transform:scale(1.15)}
.ad-body{padding:14px}
.ad-cat{font-size:0.66rem;font-weight:600;text-transform:uppercase;letter-spacing:0.08em;color:var(--green);margin-bottom:4px}
.ad-title{font-family:'Syne',sans-serif;font-size:0.95rem;font-weight:700;color:var(--ink);line-height:1.3;margin-bottom:6px}
.ad-price{font-family:'Syne',sans-serif;font-size:1.1rem;font-weight:800;color:var(--green)}
.ad-price-old{font-size:0.78rem;color:var(--ink3);text-decoration:line-through;margin-left:6px}
.ad-meta{display:flex;align-items:center;justify-content:space-between;margin-top:10px;padding-top:10px;border-top:1px solid var(--border)}
.ad-loc{font-size:0.72rem;color:var(--ink3);display:flex;align-items:center;gap:3px}
.ad-time{font-size:0.68rem;color:var(--ink3)}

/* ══ POST AD ══ */
.post-page{max-width:680px;margin:0 auto;padding:30px 20px 60px}
.form-card{background:var(--white);border:1.5px solid var(--border);border-radius:var(--r2);padding:28px;box-shadow:var(--shadow);animation:fadeUp 0.4s ease both}
.form-title{font-family:'Syne',sans-serif;font-size:1.3rem;font-weight:800;margin-bottom:4px}
.form-sub{font-size:0.82rem;color:var(--ink3);margin-bottom:24px}
.step-bar{display:flex;gap:0;margin-bottom:28px;background:var(--bg2);border-radius:var(--r);overflow:hidden}
.step-tab{flex:1;padding:10px;text-align:center;font-size:0.78rem;font-weight:700;color:var(--ink3);cursor:pointer;transition:all 0.25s;border:none;background:transparent}
.step-tab.active{background:var(--green);color:var(--white)}
.step-tab.done{background:var(--green3);color:var(--green)}
.form-group{margin-bottom:16px}
.form-label{display:block;font-size:0.78rem;font-weight:700;color:var(--ink2);margin-bottom:5px;text-transform:uppercase;letter-spacing:0.04em}
.form-input{width:100%;padding:12px 14px;background:var(--bg);border:1.5px solid var(--border);border-radius:var(--r);color:var(--ink);font-family:'Inter',sans-serif;font-size:0.88rem;outline:none;transition:border-color 0.2s}
.form-input:focus{border-color:var(--green);box-shadow:0 0 0 3px var(--green4)}
.form-input::placeholder{color:var(--ink3)}
select.form-input{cursor:pointer}
textarea.form-input{resize:vertical;min-height:100px}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.btn-block{width:100%;padding:13px;background:var(--green);color:var(--white);border:none;border-radius:var(--r);font-family:'Syne',sans-serif;font-size:0.92rem;font-weight:800;cursor:pointer;transition:all 0.2s;letter-spacing:0.01em}
.btn-block:hover{background:var(--green2);transform:translateY(-1px)}
.btn-secondary{width:100%;padding:13px;background:transparent;color:var(--ink2);border:1.5px solid var(--border);border-radius:var(--r);font-family:'Syne',sans-serif;font-size:0.88rem;font-weight:700;cursor:pointer;transition:all 0.2s}
.btn-secondary:hover{background:var(--bg2)}
.two-btns{display:grid;grid-template-columns:1fr 2fr;gap:10px}

/* image upload zone */
.upload-zone{border:2px dashed var(--border2);border-radius:var(--r2);padding:32px;text-align:center;cursor:pointer;transition:all 0.2s;background:var(--bg)}
.upload-zone:hover{border-color:var(--green);background:var(--green3)}
.upload-icon{font-size:2.2rem;margin-bottom:8px}
.upload-txt{font-size:0.82rem;color:var(--ink3)}
.upload-hint{font-size:0.72rem;color:var(--ink3);margin-top:4px}
.imgs-preview{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}
.img-prev{width:72px;height:72px;border-radius:8px;background:var(--bg2);border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:1.5rem;position:relative;cursor:pointer}
.img-rm{position:absolute;top:-6px;right:-6px;width:18px;height:18px;background:var(--red);border-radius:50%;color:var(--white);font-size:0.65rem;display:flex;align-items:center;justify-content:center;border:none;cursor:pointer}

/* plan cards */
.plan-cards{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;margin-bottom:16px}
.plan-card{border:2px solid var(--border);border-radius:var(--r2);padding:16px;text-align:center;cursor:pointer;transition:all 0.2s}
.plan-card:hover,.plan-card.sel{border-color:var(--green);background:var(--green3)}
.plan-icon{font-size:1.5rem;margin-bottom:6px}
.plan-name{font-family:'Syne',sans-serif;font-size:0.88rem;font-weight:800;color:var(--ink)}
.plan-price{font-size:0.78rem;color:var(--green);font-weight:600;margin-top:3px}
.plan-feats{font-size:0.68rem;color:var(--ink3);margin-top:4px;line-height:1.5}
.plan-card.sel .plan-name{color:var(--green)}

/* success */
.success-wrap{text-align:center;padding:20px 0}
.success-icon{font-size:4rem;margin-bottom:16px}
.success-title{font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800;color:var(--green);margin-bottom:8px}
.success-sub{font-size:0.86rem;color:var(--ink3);line-height:1.65;max-width:360px;margin:0 auto}
.ref-box{font-size:0.78rem;color:var(--ink3);margin-top:12px;padding:10px;background:var(--bg2);border-radius:8px;font-family:monospace}
.success-btns{display:flex;gap:8px;justify-content:center;margin-top:20px;flex-wrap:wrap}

/* ══ AD DETAIL ══ */
.detail-page{max-width:900px;margin:0 auto;padding:24px 20px 60px}
.detail-grid{display:grid;grid-template-columns:1fr 320px;gap:20px}
.detail-imgs{background:var(--bg2);border:1.5px solid var(--border);border-radius:var(--r2);height:320px;display:flex;align-items:center;justify-content:center;font-size:5rem;margin-bottom:12px;overflow:hidden}
.detail-thumbs{display:flex;gap:8px}
.detail-thumb{width:60px;height:60px;background:var(--bg2);border:1.5px solid var(--border);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:1.4rem;cursor:pointer;transition:border-color 0.2s}
.detail-thumb:hover,.detail-thumb.sel{border-color:var(--green)}
.detail-title{font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800;color:var(--ink);margin-bottom:8px;line-height:1.2}
.detail-price{font-family:'Syne',sans-serif;font-size:2rem;font-weight:800;color:var(--green);margin-bottom:12px}
.detail-meta{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:16px}
.dmeta{font-size:0.78rem;color:var(--ink3);display:flex;align-items:center;gap:4px}
.detail-desc{font-size:0.88rem;color:var(--ink2);line-height:1.75;margin-bottom:20px}
.detail-tags{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:20px}
.dtag{padding:4px 12px;background:var(--bg2);border:1px solid var(--border);border-radius:100px;font-size:0.72rem;color:var(--ink3)}
.seller-card{background:var(--white);border:1.5px solid var(--border);border-radius:var(--r2);padding:20px;margin-bottom:14px}
.seller-head{display:flex;align-items:center;gap:12px;margin-bottom:14px}
.seller-avatar{width:48px;height:48px;border-radius:12px;background:var(--green);color:var(--white);display:flex;align-items:center;justify-content:center;font-weight:800;font-size:1rem;flex-shrink:0}
.seller-name{font-family:'Syne',sans-serif;font-size:0.95rem;font-weight:800}
.seller-since{font-size:0.72rem;color:var(--ink3);margin-top:2px}
.seller-stats{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:14px}
.sstat{background:var(--bg2);border-radius:8px;padding:10px;text-align:center}
.sstat-n{font-family:'Syne',sans-serif;font-size:1rem;font-weight:800;color:var(--ink)}
.sstat-l{font-size:0.65rem;color:var(--ink3);margin-top:1px}
.btn-call{width:100%;padding:12px;background:var(--green);color:var(--white);border:none;border-radius:var(--r);font-family:'Syne',sans-serif;font-size:0.88rem;font-weight:800;cursor:pointer;transition:all 0.2s;margin-bottom:8px;display:flex;align-items:center;justify-content:center;gap:6px}
.btn-call:hover{background:var(--green2)}
.btn-msg{width:100%;padding:12px;background:transparent;color:var(--green);border:1.5px solid var(--green);border-radius:var(--r);font-family:'Syne',sans-serif;font-size:0.88rem;font-weight:800;cursor:pointer;transition:all 0.2s;display:flex;align-items:center;justify-content:center;gap:6px}
.btn-msg:hover{background:var(--green3)}
.safety-box{background:var(--gold2);border:1px solid var(--gold);border-radius:var(--r);padding:12px 14px;font-size:0.76rem;color:var(--ink2);line-height:1.55;margin-top:14px}

/* ══ PROFILE ══ */
.profile-page{max-width:900px;margin:0 auto;padding:24px 20px 60px}
.profile-hero{background:var(--ink);color:var(--white);border-radius:var(--r2);padding:28px;margin-bottom:20px;position:relative;overflow:hidden}
.profile-hero::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse 60% 80% at 80% 50%,rgba(27,107,69,0.3),transparent 60%)}
.profile-top{display:flex;align-items:center;gap:16px;margin-bottom:20px;position:relative}
.profile-avatar{width:64px;height:64px;border-radius:14px;background:var(--green);color:var(--white);display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-size:1.5rem;font-weight:800;border:3px solid rgba(255,255,255,0.2)}
.profile-name{font-family:'Syne',sans-serif;font-size:1.3rem;font-weight:800}
.profile-loc{font-size:0.78rem;color:rgba(255,255,255,0.6);margin-top:3px}
.profile-stats{display:flex;gap:0;position:relative}
.pstat{flex:1;text-align:center;padding:12px 0;border-right:1px solid rgba(255,255,255,0.1)}
.pstat:last-child{border-right:none}
.pstat-n{font-family:'Syne',sans-serif;font-size:1.3rem;font-weight:800;color:var(--white)}
.pstat-l{font-size:0.66rem;color:rgba(255,255,255,0.5);margin-top:2px}
.profile-grid{display:grid;grid-template-columns:1fr 280px;gap:18px}
.my-ads-list{display:flex;flex-direction:column;gap:10px}
.my-ad-item{background:var(--white);border:1.5px solid var(--border);border-radius:var(--r2);padding:14px;display:flex;align-items:center;gap:12px;transition:border-color 0.2s;cursor:pointer}
.my-ad-item:hover{border-color:var(--green)}
.my-ad-icon{width:52px;height:52px;border-radius:10px;background:var(--bg2);display:flex;align-items:center;justify-content:center;font-size:1.4rem;flex-shrink:0}
.my-ad-name{font-family:'Syne',sans-serif;font-size:0.9rem;font-weight:700;margin-bottom:3px}
.my-ad-price{font-size:0.82rem;color:var(--green);font-weight:600}
.my-ad-meta{font-size:0.7rem;color:var(--ink3);margin-top:2px}
.my-ad-actions{display:flex;gap:6px;margin-left:auto}
