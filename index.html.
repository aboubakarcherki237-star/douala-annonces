  } else if(postStep===2){
    c.innerHTML=`
      <div class="upload-zone" onclick="fakeUpload()">
        <div class="upload-icon">📷</div>
        <div class="upload-txt">Cliquez pour ajouter des photos</div>
        <div class="upload-hint">Jusqu'à 10 photos • JPG, PNG • Max 5Mo chacune</div>
