      <div style="margin-top:14px;padding:12px;background:var(--bg2);border-radius:var(--r);font-size:0.78rem;color:var(--ink3)">
        💡 <strong>Conseil :</strong> Les annonces avec photos reçoivent 5x plus de contacts. Prenez des photos claires, bien éclairées.
      </div>
      <div class="two-btns" style="margin-top:16px">
        <button class="btn-secondary" onclick="prevPost()">← Retour</button>
        <button class="btn-block" style="margin-top:0" onclick="nextPost()">Continuer →</button>
      </div>`;
  } else if(postStep===3){
    c.innerHTML=`
      <div class="form-group"><label class="form-label">Ville / Quartier *</label>
        <select class="form-input" id="pCity">
          <option>Douala — Akwa</option><option>Douala — Bonamoussadi</option><option>Douala — Makepe</option>
