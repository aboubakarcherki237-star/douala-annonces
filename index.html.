function nextPost(){
  if(postStep===1){
    const cat=document.getElementById('pCat').value;
    const title=document.getElementById('pTitle').value;
    const desc=document.getElementById('pDesc').value;
    const price=document.getElementById('pPrice').value;
    if(!cat||!title||!desc||!price){ showToast('⚠️','Remplissez tous les champs obligatoires'); return; }
    postData={...postData,cat,title,desc,price};
  }
  if(postStep===3){
    const phone=document.getElementById('pPhone').value;
    if(!phone){ showToast('⚠️','Votre numéro de téléphone est obligatoire'); return; }
    postData={...postData,phone};
  }
  postStep++;
  renderPostStep();
}

function prevPost(){ if(postStep>1){ postStep--; renderPostStep(); } }

function selPostPlan(plan){ selPlan=plan; renderPostStep(); }

const EMOJIS=['📱','👗','📷','🎮','🏠','🚗'];
let imgIdx=0;
function fakeUpload(){
  if(uploadedImgs.length>=10){ showToast('⚠️','Maximum 10 photos'); return; }
  uploadedImgs.push(EMOJIS[imgIdx%EMOJIS.length]);
  imgIdx++;
  renderPostStep();
  showToast('📷','Photo ajoutée');
}

function rmImg(i){ uploadedImgs.splice(i,1); renderPostStep(); }

function publishAd(){
  const btn=document.querySelector('#postContent .btn-block:last-child');
  if(btn){ btn.innerHTML='<span class="spinner"></span> Publication...'; btn.disabled=true; }
  setTimeout(()=>{ postStep=5; renderPostStep(); },1500);
}

